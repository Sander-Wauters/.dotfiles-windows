{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.2.0/resources/zpack-schema.json",
  "name": "dwmblocks",
  "version": "0.0.0",
  "description": "",
  "tags": [],
  "previewImages": ["./resources/preview-image-1.png"],
  "repositoryUrl": "",
  "widgets": [
    {
      "name": "with-glazewm",
      "htmlPath": "with-glazewm/index.html",
      "zOrder": "normal",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": false,
      "includeFiles": ["with-glazewm/**"],
      "caching": {
        "defaultDuration": 604800,
        "rules": []
      },
      "privileges": {
        "shellCommands": []
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "24px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": false,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    }
  ]
}
